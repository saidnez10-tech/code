#Get the base number from the user
base_number=float(input("enter the base number"))
#Get the exponent n to enter it from user
n=int(input("enter a number"))
#Use for loop
for i in range(1,n+1):
    result=base_number ** n
    #Print the result
    print(f"{base_number} raised to the power of {i} is {result}")